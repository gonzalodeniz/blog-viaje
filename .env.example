# Copia este fichero a .env y ajusta los valores. .env NUNCA se comitea.

# Dominio público del blog (nginx / certbot)
BITACORA_DOMAIN=blog.example.com
LETSENCRYPT_EMAIL=tu-correo@example.com

# PostgreSQL (red interna; no se expone al exterior)
POSTGRES_DB=bitacora
POSTGRES_USER=bitacora
POSTGRES_PASSWORD=cambia-esto-por-un-valor-largo-y-aleatorio

# Backend
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
# Sesiones (RF-R1-02): horas sin remember-me / días con remember-me / tope absoluto en días
SESSION_TTL_HOURS=24
SESSION_REMEMBER_DAYS=30
SESSION_ABSOLUTE_MAX_DAYS=90
# Retención de login_attempts en días (RNF-R1-08)
LOGIN_ATTEMPTS_RETENTION_DAYS=90
